---
import { translations } from "../i18n/translations";
import type { Lang } from "../i18n/utils";

interface Props { lang?: Lang; }
const { lang = "fr" } = Astro.props;
const t = translations[lang];
const base = `/${lang}`;
const PHONE = "+41754147697";
const PHONE_DISPLAY = "075 414 76 97";
const links = [
  { name: t.nav_entreprise, href: `${base}/#entreprise` },
  { name: t.nav_services, href: `${base}/#services` },
  { name: t.nav_galerie, href: `${base}/#galerie` },
  { name: t.nav_contact, href: `${base}/#contact` },
];
---

<header id="desktop-header" class="hidden lg:flex fixed top-0 w-full z-50 transition-all duration-500 h-28 items-center justify-between px-10 bg-transparent border-b border-transparent">
    <a href={`${base}/`} class="flex items-center gap-3 group" aria-label="Ruchet Paysage — Accueil">
        <img src="/logo.png" alt="Ruchet Paysage" class="h-14 w-auto" width="200" height="56" />
    </a>

    <nav class="flex gap-10 text-[11px] font-bold text-[var(--color-text-primary)] uppercase tracking-[0.2em]">
        {links.map(link => (
            <a href={link.href} class="hover:text-[#2D5F3F] transition-colors py-2">{link.name}</a>
        ))}
    </nav>

    <div class="flex items-center gap-4">
        <a href={`tel:${PHONE}`} class="flex items-center gap-2 px-4 py-3 border border-[var(--color-border)] rounded-full text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--color-text-primary)] hover:border-[#2D5F3F] hover:text-[#2D5F3F] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg>
            <span>{PHONE_DISPLAY}</span>
        </a>
        <a href={`${base}/#contact`} class="px-8 py-4 bg-[#2D5F3F] text-white text-[11px] font-bold uppercase tracking-[0.2em] hover:bg-[#1f4a30] transition-colors rounded-lg">{t.nav_cta_devis}</a>
    </div>
</header>

<div class="lg:hidden fixed top-4 left-4 z-40 pointer-events-none drop-shadow">
    <a href={`${base}/`} class="pointer-events-auto inline-flex" aria-label="Ruchet Paysage — Accueil">
        <img src="/logo.png" alt="Ruchet Paysage" class="h-10 w-auto bg-white/85 backdrop-blur-sm rounded px-2 py-1" width="120" height="40" />
    </a>
</div>

<!-- Dock mobile centré style pastille liquid glass -->
<div class="mobile-dock lg:hidden" aria-label="Actions principales">
    <div class="mobile-dock-inner">
        <a href={`tel:${PHONE}`} class="dock-btn dock-btn-phone" aria-label={`Appeler ${PHONE_DISPLAY}`}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        </a>
        <span class="dock-sep"></span>
        <button id="mobile-menu-btn" class="dock-btn dock-btn-menu" aria-label={t.aria_menu}>
            <div id="icon-burger" class="flex flex-col gap-1.5 transition-all duration-300">
                <span class="w-5 h-0.5 bg-[#2D5F3F] block"></span>
                <span class="w-3.5 h-0.5 bg-[#2D5F3F] block ml-auto"></span>
                <span class="w-5 h-0.5 bg-[#2D5F3F] block"></span>
            </div>
            <svg id="icon-close" class="w-6 h-6 absolute opacity-0 rotate-90 transition-all duration-300 text-[#2D5F3F] pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>
</div>

<style>
    .mobile-dock { position: fixed; bottom: calc(1.5rem + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); z-index: 60; display: flex; justify-content: center; }
    @media (min-width: 1024px) { .mobile-dock { display: none !important; } }
    .mobile-dock-inner { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 99px; background: rgba(255,255,255,0.92); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%); border: 1px solid rgba(11,31,18,0.08); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
    .dock-btn { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.2s ease; box-shadow: 0 4px 14px rgba(0,0,0,0.1); text-decoration: none; position: relative; }
    .dock-btn:active { transform: scale(0.9); }
    .dock-btn-phone { background: #2D5F3F; color: #fff; }
    .dock-btn-menu { background: #fff; color: #2D5F3F; border: 1px solid rgba(45,95,63,0.2); }
    .dock-sep { width: 1px; height: 28px; background: rgba(11,31,18,0.12); flex-shrink: 0; }
    .menu-overlay { background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transition: opacity 0.4s; }
    .menu-panel-drawer { background: var(--color-bg-primary); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%); border-left: 2px solid rgba(45, 95, 63, 0.4); box-shadow: inset 0 1px 1px var(--color-border), -8px 0 32px rgba(0,0,0,0.5); }
    .drawer-close-btn { display: flex; align-items: center; justify-content: center; min-width: 44px; min-height: 44px; position: absolute; top: 16px; right: 16px; padding: 10px; border-radius: 4px; background: transparent; border: 1px solid rgba(45, 95, 63, 0.5); color: #2D5F3F; cursor: pointer; transition: background 0.2s, color 0.2s; }
    .drawer-close-btn:hover { background: rgba(45, 95, 63, 0.2); color: #fff; }
    .drawer-nav-link { text-transform: uppercase !important; letter-spacing: 0.08em !important; font-style: normal !important; }
</style>

<div id="menu-backdrop" class="menu-overlay fixed inset-0 z-[65] hidden opacity-0 transition-opacity duration-400 lg:hidden"></div>

<div id="mobile-drawer" class="menu-panel-drawer fixed top-0 right-0 h-[100dvh] w-[85%] max-w-[320px] z-[70] transform translate-x-full transition-transform duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] flex flex-col lg:hidden touch-pan-y rounded-l-[32px]">
    <button id="drawer-close-btn" type="button" class="drawer-close-btn" aria-label="Fermer le menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <div id="mobile-drawer-panel" class="p-10 pt-24 flex flex-col h-full">
        <p class="text-[10px] uppercase tracking-widest text-[var(--color-text-secondary)] mb-6 flex items-center gap-2" aria-hidden="true">
            <span class="inline-block w-8 h-0.5 bg-current opacity-60 rounded"></span>
            {t.drawer_swipe_hint}
        </p>
        <nav class="flex flex-col gap-8">
            {links.map((link, i) => (
                <a href={link.href} class="drawer-link drawer-nav-link text-3xl font-serif text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] transition-colors hover:translate-x-2 duration-300 flex items-center gap-4 group">
                    <span class="text-xs font-sans text-[#2D5F3F] font-bold opacity-0 group-hover:opacity-100 transition-opacity">0{i+1}</span>
                    {link.name}
                </a>
            ))}
            <a href={`${base}/#contact`} class="drawer-link drawer-nav-link text-3xl font-serif text-[#2D5F3F] hover:text-[var(--color-text-primary)] transition-colors hover:translate-x-2 duration-300 mt-4 flex items-center gap-4 group">
                <span class="text-xs font-sans text-[var(--color-text-primary)] font-bold opacity-0 group-hover:opacity-100 transition-opacity">04</span>
                {t.drawer_devis}
            </a>
        </nav>

        <div class="mt-auto mb-8 border-t border-[var(--color-border)]"></div>
        <div class="flex items-center gap-4 text-[var(--color-text-secondary)]">
             <a href="https://www.facebook.com/profile.php?id=61578599286003" target="_blank" rel="noopener" class="hover:text-[#2D5F3F]">Facebook</a>
             <a href="https://www.instagram.com/julien_ruchet/" target="_blank" rel="noopener" class="hover:text-[#2D5F3F]">Instagram</a>
        </div>
    </div>
</div>

<script>
    const header = document.getElementById('desktop-header');
    window.addEventListener('scroll', () => {
        if (!header) return;
        if (window.scrollY > 50) { 
            header.classList.remove('bg-transparent', 'h-28', 'border-transparent'); 
            header.classList.add('bg-[var(--color-bg-primary)]', 'opacity-95', 'backdrop-blur-md', 'h-20', 'border-[var(--color-border)]'); 
        } else { 
            header.classList.add('bg-transparent', 'h-28', 'border-transparent'); 
            header.classList.remove('bg-[var(--color-bg-primary)]', 'opacity-95', 'backdrop-blur-md', 'h-20', 'border-[var(--color-border)]'); 
        }
    });

    const btn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('menu-backdrop');
    const iconBurger = document.getElementById('icon-burger');
    const iconClose = document.getElementById('icon-close');
    let isOpen = false;

    function toggleMenu() {
        if (!drawer || !backdrop || !iconBurger || !iconClose) return;
        isOpen = !isOpen;
        if (isOpen) {
            drawer.classList.remove('translate-x-full');
            backdrop.classList.remove('hidden');
            setTimeout(() => backdrop.classList.remove('opacity-0'), 10);
            iconBurger.classList.add('opacity-0', 'rotate-90');
            iconClose.classList.remove('opacity-0', 'rotate-90');
            document.body.style.overflow = 'hidden';
        } else {
            drawer.classList.add('translate-x-full');
            backdrop.classList.add('opacity-0');
            setTimeout(() => backdrop.classList.add('hidden'), 500);
            iconBurger.classList.remove('opacity-0', 'rotate-90');
            iconClose.classList.add('opacity-0', 'rotate-90');
            document.body.style.overflow = '';
        }
    }

    btn?.addEventListener('click', toggleMenu);
    document.getElementById('drawer-close-btn')?.addEventListener('click', () => { if (isOpen) toggleMenu(); });
    backdrop?.addEventListener('click', toggleMenu);
    document.querySelectorAll('.drawer-link').forEach(l => l.addEventListener('click', () => { if(isOpen) toggleMenu(); }));

    let touchStartX = 0;
    const drawerPanel = document.getElementById('mobile-drawer-panel');
    drawerPanel?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
    drawerPanel?.addEventListener('touchend', (e) => {
        if (!isOpen) return;
        const touchEndX = e.changedTouches[0].clientX;
        if (touchEndX - touchStartX > 60) toggleMenu();
    }, { passive: true });
</script>